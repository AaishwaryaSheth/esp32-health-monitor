#pragma once

// ===================== SECRETS TEMPLATE =====================
// Copy this file to app_secrets.h and fill in your real values.
//   cp main/app_secrets.h.example main/app_secrets.h
// app_secrets.h is git-ignored so your real credentials never get committed.

// --- WiFi (2.4 GHz only — ESP32 does not support 5 GHz) ---
#define WIFI_SSID        "YOUR_WIFI_SSID"
#define WIFI_PASSWORD    "YOUR_WIFI_PASSWORD"

// --- HiveMQ Cloud (free tier) ---
// Host is the Cluster URL from the HiveMQ Cloud console (Overview).
// Must be a full URI with the mqtts:// scheme and :8883 TLS port.
#define MQTT_BROKER_URI  "mqtts://YOUR-CLUSTER.s1.eu.hivemq.cloud:8883"
#define MQTT_USERNAME    "YOUR_HIVEMQ_USERNAME"
#define MQTT_PASSWORD    "YOUR_HIVEMQ_PASSWORD"
